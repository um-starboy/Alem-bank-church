# ── PostgreSQL (Railway gives you this automatically) ──────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── JWT Secrets (generate random strings, keep them SECRET) ────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS - set to your frontend URL in production ──────────────────────────
CLIENT_URL=http://localhost:3000

# ── Super Admin seed (used once on first run) ───────────────────────────────
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=Change_This_Password_123!
SEED_ADMIN_EMAIL=admin@alembank.church

# ── Cloudinary (get from cloudinary.com dashboard) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
